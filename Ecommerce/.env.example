# Copy to .env and fill values

DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# PostgreSQL
DB_NAME=flipmart
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=127.0.0.1
DB_PORT=5432

# Email (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=FlipMart <noreply@example.com>

# Google OAuth (django-allauth) — create at https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Site URL (for OAuth callbacks)
SITE_URL=http://127.0.0.1:8000

# Twilio (SMS OTP — optional; email OTP works without)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Razorpay (https://dashboard.razorpay.com/)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
